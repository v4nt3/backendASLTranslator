CHECKPOINT_PATH=models/best_model.pt
CONFIG_PATH=config.yaml
LABELS_PATH=models/labels.json
DEVICE=cpu

# --- CORS origins (comma-separated) ---
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080


# API Key: if not set, authentication is DISABLED (dev mode).
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=your_api_key


# Rate limiting: max requests per IP within the time window
RATE_LIMIT_MAX_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60

# Concurrency: max simultaneous model inferences
MAX_CONCURRENT_INFERENCES=2

# Input limits: max frames accepted per request
MAX_FRAMES_PER_REQUEST=512
